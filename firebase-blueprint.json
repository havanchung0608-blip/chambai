{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system (Teacher or Student).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "fullName": { "type": "string" },
        "className": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Exam": {
      "title": "Exam",
      "description": "An exam created by a teacher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "examCode": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "pdfFileName": { "type": "string" },
        "answerPdfUrl": { "type": "string" },
        "answerPdfFileName": { "type": "string" },
        "rubricText": { "type": "string" },
        "aiInstruction": { "type": "string" },
        "fileMime": { "type": "string" },
        "fileHtml": { "type": "string" },
        "rubric": { "type": "string" },
        "isLocked": { "type": "boolean" },
        "isDeleted": { "type": "boolean" },
        "deletedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherId", "examCode", "title"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A student's submission for an exam.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "examId": { "type": "string" },
        "examCode": { "type": "string" },
        "examTitle": { "type": "string" },
        "teacherId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "studentClass": { "type": "string" },
        "studentEmail": { "type": "string" },
        "uploadedImageUrls": { "type": "array", "items": { "type": "string" } },
        "usedAnswerPdfUrl": { "type": "string" },
        "aiStatus": { "type": "string" },
        "aiTotalScore": { "type": "number" },
        "aiMaxTotalScore": { "type": "number" },
        "aiScoreByQuestion": { "type": "array", "items": { "type": "object" } },
        "aiDetailedFeedback": { "type": "string" },
        "aiMistakes": { "type": "string" },
        "aiSuggestions": { "type": "string" },
        "needTeacherReview": { "type": "boolean" },
        "isDeleted": { "type": "boolean" },
        "deletedAt": { "type": "string", "format": "date-time" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Đã chấm", "Chưa chấm", "Lỗi ảnh"] }
      },
      "required": ["examId", "examCode", "studentId", "uploadedImageUrls"]
    },
    "ExamCodeChangeLog": {
      "title": "ExamCodeChangeLog",
      "description": "Log entry for when an exam code is changed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "examId": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherEmail": { "type": "string" },
        "oldExamCode": { "type": "string" },
        "newExamCode": { "type": "string" },
        "changedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["examId", "teacherId", "oldExamCode", "newExamCode", "changedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings."
    },
    "/exams/{examId}": {
      "schema": "Exam",
      "description": "Collection of exams created by teachers."
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Student submissions for exams."
    },
    "/examCodeChangeLogs/{logId}": {
      "schema": "ExamCodeChangeLog",
      "description": "Logs for exam code changes."
    }
  }
}
