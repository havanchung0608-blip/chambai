rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- USERS ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId) && 
        isValidId(userId) &&
        incoming().uid == userId &&
        incoming().email == request.auth.token.email;
    }

    // --- EXAMS ---
    match /exams/{examId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
        isValidId(examId) &&
        incoming().teacherId == request.auth.uid;
      allow update, delete: if isSignedIn() && 
        isValidId(examId) &&
        existing().teacherId == request.auth.uid;
    }

    // --- SUBMISSIONS ---
    match /submissions/{submissionId} {
      function canAccessSubmission(data) {
        return data.teacherId == request.auth.uid || 
               data.studentId == request.auth.uid ||
               get(/databases/$(database)/documents/exams/$(data.examId)).data.teacherId == request.auth.uid;
      }

      allow list: if isSignedIn() && canAccessSubmission(resource.data);
      allow get: if isSignedIn() && isValidId(submissionId) && canAccessSubmission(resource.data);

      allow create: if isSignedIn() && 
        isValidId(submissionId) &&
        incoming().studentId == request.auth.uid;

      allow update: if isSignedIn() && 
        isValidId(submissionId) &&
        canAccessSubmission(existing());
      
      allow delete: if isSignedIn() && 
        isValidId(submissionId) &&
        (existing().teacherId == request.auth.uid || 
         get(/databases/$(database)/documents/exams/$(existing().examId)).data.teacherId == request.auth.uid);
    }

    // --- LOGS ---
    match /examCodeChangeLogs/{logId} {
      allow read: if isSignedIn() && 
        isValidId(logId) &&
        existing().teacherId == request.auth.uid;
      allow create: if isSignedIn() && 
        isValidId(logId) &&
        incoming().teacherId == request.auth.uid &&
        get(/databases/$(database)/documents/exams/$(incoming().examId)).data.teacherId == request.auth.uid;
    }
  }
}
